{
  "name": "@mvtcode/vue3-querybuilder-naive-ui",
  "version": "0.0.1",
  "description": "A powerful and flexible query builder component for Vue 3 with Naive UI",
  "keywords": [
    "vue",
    "vue3",
    "query-builder",
    "naive-ui",
    "typescript"
  ],
  "author": "tanmv",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:mvtcode/vue3-querybuilder-naive-ui.git"
  },
  "private": false,
  "type": "module",
  "main": "dist/vue3-querybuilder-naive-ui.umd.js",
  "module": "dist/vue3-querybuilder-naive-ui.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "dist/**/*.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue3-querybuilder-naive-ui.es.js",
      "require": "./dist/vue3-querybuilder-naive-ui.umd.js"
    },
    "./style.css": "./dist/vue3-querybuilder-naive-ui.css"
  },
  "peerDependencies": {
    "naive-ui": "^2.0.0",
    "vue": "^3.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --build tsconfig.build.json && vite build",
    "build-only": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/"
  },
  "dependencies": {
    "dayjs": "^1.11.10",
    "vue-i18n": "^11.3.2"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.0",
    "@vicons/ionicons5": "^0.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^4.2.0",
    "@vitest/eslint-plugin": "^1.6.13",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "naive-ui": "^2.41.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.42.0",
    "oxlint": "~1.57.0",
    "typescript": "~5.8.0",
    "vite": "^6.2.4",
    "vite-plugin-vue-devtools": "^7.7.7",
    "vitest": "^3.1.1",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.8"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
